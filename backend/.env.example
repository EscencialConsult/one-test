# Copiá este archivo como .env y completá los valores.

# Base de datos PostgreSQL (Render → Internal/External Database URL)
# Render entrega algo como: postgresql://usuario:password@host:5432/dbname
DATABASE_URL=postgresql://usuario:password@localhost:5432/plataforma_one

# Clave para firmar los tokens de sesión (JWT). Generá una larga y aleatoria.
SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta

# Duración del token de acceso (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Entorno: dev | prod
ENV=dev

# SSL para la base de datos. true para Render (conexión externa). false para Postgres local sin SSL.
DB_SSL=true

# Orígenes permitidos para el frontend (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Correo (SMTP) ─────────────────────────────────────────────
# Si SMTP_HOST queda vacío, no se envían correos (no rompe nada).
# Ejemplos de host: smtp.gmail.com (587), smtp-relay.brevo.com (587), etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@escencial.com
SMTP_FROM_NAME=PACK ONE MATCH
SMTP_STARTTLS=true

# ── URLs para los links de los correos ────────────────────────
# URL principal del frontend (mientras no haya subdominios).
PUBLIC_BASE_URL=http://localhost:5173
# Dominio para subdominios por empresa (ej. one.com → https://techsur.one.com). Vacío hasta comprarlo.
TENANT_DOMAIN=
